# AI Provider (OpenAI, Gemini, Local Llama, etc)
OPENAI_API_KEY=sk-mock-key-for-local-dev
USE_MOCK_AI=true # Set to false to use actual API

# Database
POSTGRES_USER=callguard
POSTGRES_PASSWORD=securepassword
POSTGRES_DB=callguard_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Kafka
KAFKA_BROKER_URL=kafka:9092
KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181

# API Gateway
API_SECRET_KEY=super-secret-jwt-key
API_PORT=8000
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8001/ws
